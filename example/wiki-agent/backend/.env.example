# ZhipuAI (GLM)
ZHIPUAI_API_KEY=your_api_key_here
ZHIPUAI_CHAT_MODEL=glm-4
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 知识库目录（默认为项目根目录下的 knowledge/）
# KNOWLEDGE_DIR=/path/to/knowledge

# ChromaDB 目录
# CHROMA_DIR=/path/to/chroma_db

# Embedding 模型路径
# EMBEDDING_MODEL_PATH=/path/to/bge-small-zh-v1.5

# Git 版本管理
GIT_ENABLED=true
