# ===========================================
# Agent Runtime Evaluation Platform
# Environment Configuration
# ===========================================

# Application
APP_NAME="Agent Evaluation Platform"
APP_ENV="development"
DEBUG=true
SECRET_KEY="your-secret-key-change-in-production"

# Server
HOST="0.0.0.0"
PORT=8000

# Database (SQLite for development)
DATABASE_URL="sqlite+aiosqlite:///./agent_eval.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/agent_eval"

# Redis (optional)
REDIS_URL="redis://localhost:6379/0"

# ===========================================
# LLM Configuration
# ===========================================

# DeepSeek API (Recommended - Cost effective)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# OpenAI API (Optional)
OPENAI_API_KEY=""

# Anthropic API (Optional)
ANTHROPIC_API_KEY=""

# Default LLM Provider: "deepseek", "openai", or "anthropic"
DEFAULT_LLM_PROVIDER="deepseek"
DEFAULT_LLM_MODEL="deepseek-chat"

# ===========================================
# Observability
# ===========================================
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
ENABLE_TRACING=true

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
