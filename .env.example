# ===========================================
# Agent Runtime Evaluation Platform
# Environment Configuration
# ===========================================

# Application
APP_NAME="Agent Evaluation Platform"
APP_ENV="development"
DEBUG=true
SQL_ECHO=false
SECRET_KEY="your-secret-key-change-in-production"

# Server
HOST="0.0.0.0"
PORT=8000

# Database (SQLite for development)
DATABASE_URL="sqlite+aiosqlite:///./agent_eval.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/agent_eval"

# Redis (optional)
REDIS_URL="redis://localhost:6379/0"

# ===========================================
# LLM Configuration
# ===========================================

# DeepSeek API (Recommended - Cost effective)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# OpenAI API (Optional)
OPENAI_API_KEY=""

# Anthropic API (Optional)
ANTHROPIC_API_KEY=""

# ZhipuAI (GLM) API
ZHIPUAI_API_KEY=""
ZHIPUAI_MODEL="glm-4"

# Qwen (DashScope) API — OpenAI 兼容
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# Default LLM Provider: "deepseek", "openai", "anthropic", "glm", "qwen"
DEFAULT_LLM_PROVIDER="deepseek"
DEFAULT_LLM_MODEL="deepseek-chat"

# ===========================================
# Observability
# ===========================================
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
ENABLE_TRACING=true

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ===========================================
# Wiki Agent (uses DeepSeek — same keys as above)
# ===========================================
GIT_ENABLED=true

# Report wiki-agent trajectories to this platform (same server after integration)
EVAL_ENABLED=true
EVAL_API_BASE_URL="http://127.0.0.1:8000"
EVAL_AUTO_RUN=false

# Milvus vector store (local file by default; use http://localhost:19530 for Milvus server)
# MILVUS_URI="data/wiki_agent/milvus.db"
# MILVUS_COLLECTION="wiki_knowledge"
# EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"
