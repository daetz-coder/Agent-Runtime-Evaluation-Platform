# ===========================================
# Agent Runtime Evaluation Platform
# Environment Configuration
# ===========================================

# Application
APP_NAME="Agent Evaluation Platform"
APP_ENV="development"
DEBUG=true
SQL_ECHO=false
SECRET_KEY="your-secret-key-change-in-production"

# Server
HOST="0.0.0.0"
PORT=8000

# Database (SQLite for development)
DATABASE_URL="sqlite+aiosqlite:///./agent_eval.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/agent_eval"

# Redis (optional — app works without Redis via graceful degradation)
REDIS_URL="redis://localhost:6379/0"
REDIS_TIMEOUT=2
REDIS_KEY_PREFIX="eval:"

# Cache TTLs (seconds)
CACHE_LLM_RESPONSES=true          # Cache LLM evaluation responses (saves API cost)
CACHE_LLM_TTL=86400               # 24h — same trajectory+goal = same LLM result
CACHE_REPORTS_TTL=300             # 5min — report aggregation cache
CACHE_TRENDS_TTL=600              # 10min — trend data cache
CACHE_TASK_TTL=60                 # 1min — task lookup cache
CACHE_TRAJECTORY_TTL=300          # 5min — trajectory data cache
CACHE_DASHBOARD_TTL=30            # 30s — dashboard counters cache
CACHE_SESSION_TTL=3600            # 1h — Wiki Agent session cache

# Rate Limiting (requires Redis)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_EVAL_PER_MINUTE=10     # Max evaluation requests per minute per client

# ===========================================
# LLM Configuration
# ===========================================

# DeepSeek API (Recommended - Cost effective)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# OpenAI API (Optional)
OPENAI_API_KEY=""

# Anthropic API (Optional)
ANTHROPIC_API_KEY=""

# ZhipuAI (GLM) API
ZHIPUAI_API_KEY=""
ZHIPUAI_MODEL="glm-4"

# Qwen (DashScope) API — OpenAI 兼容
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# Default LLM Provider: "deepseek", "openai", "anthropic", "glm", "qwen"
DEFAULT_LLM_PROVIDER="deepseek"
DEFAULT_LLM_MODEL="deepseek-chat"

# ===========================================
# Observability
# ===========================================
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
ENABLE_TRACING=true

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ===========================================
# Wiki Agent (uses DeepSeek — same keys as above)
# ===========================================
GIT_ENABLED=true

# Report wiki-agent trajectories to this platform (same server after integration)
EVAL_ENABLED=true
EVAL_API_BASE_URL="http://127.0.0.1:8000"
EVAL_API_KEY=""
EVAL_AUTO_RUN=false

# Milvus vector store (local file by default; use http://localhost:19530 for Milvus server)
# MILVUS_URI="data/wiki_agent/milvus.db"
# MILVUS_COLLECTION="wiki_knowledge"
# EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"

# Rerank (cross-encoder after RRF hybrid search)
# RERANK_ENABLED=true
# RERANK_MODEL="BAAI/bge-reranker-v2-m3"
# RERANK_CANDIDATE_MULTIPLIER=3

# ===========================================
# Code Execution Sandbox (Docker-based)
# ===========================================
# Requires Docker daemon running. When disabled, tool_use evaluation
# falls back to LLM-only judgment (no code execution).
SANDBOX_ENABLED=false
SANDBOX_POOL_SIZE=3
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_CPU_CORES=1
SANDBOX_OUTPUT_LIMIT=10240000
SANDBOX_CACHE_TTL=86400
