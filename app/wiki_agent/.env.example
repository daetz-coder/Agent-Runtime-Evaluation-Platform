# ── Wiki Agent 配置 ──────────────────────────────────────────
# 复制为 .env 并填入实际值
# 优先级：本文件 > 项目根目录 .env

# ── LLM (DeepSeek) ─────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── LLM (ZhipuAI / GLM，可选，优先使用) ─────────────────────
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPUAI_CHAT_MODEL=glm-4-flash

# ── 知识库路径 ──────────────────────────────────────────────
# 默认在项目根目录 data/wiki_agent/ 下
# KNOWLEDGE_DIR=data/wiki_agent/knowledge
# MILVUS_URI=data/wiki_agent/milvus.db
# DB_PATH=data/wiki_agent/chat.db
# BM25_INDEX_PATH=data/wiki_agent/bm25_index.pkl

# ── Embedding 模型 ─────────────────────────────────────────
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_MODEL_PATH=example/wiki-agent/models/bge-small-zh-v1.5

# ── Query Rewrite ──────────────────────────────────────────
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_SIMILARITY_THRESHOLD=0.7
QUERY_REWRITE_MAX_QUERIES=5

# ── 对话历史窗口 ──────────────────────────────────────────
HISTORY_MAX_TURNS=10

# ── Rerank (Cross-Encoder) ─────────────────────────────────
RERANK_ENABLED=true
# RERANK_MODEL=BAAI/bge-reranker-base
# RERANK_MODEL_PATH=example/wiki-agent/models/bge-reranker-base
RERANK_CANDIDATE_MULTIPLIER=3
RERANK_MAX_LENGTH=512

# ── 缓存 ──────────────────────────────────────────────────
CACHE_SESSION_TTL=3600

# ── Git ───────────────────────────────────────────────────
GIT_ENABLED=true

# ── 评估平台（可选） ──────────────────────────────────────
EVAL_ENABLED=true
EVAL_API_BASE_URL=http://127.0.0.1:8000
EVAL_INPROCESS=true
EVAL_AUTO_RUN=false
EVAL_BATCH_SIZE=8
