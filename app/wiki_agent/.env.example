# ── Wiki Agent 配置 ──────────────────────────────────────────
# 复制为 .env 并填入实际值

# ── LLM (DeepSeek) ─────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── LLM (ZhipuAI / GLM，可选，优先使用) ─────────────────────
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPUAI_CHAT_MODEL=glm-4-flash

# ── 知识库路径（默认在 data/ 下） ──────────────────────────
# KNOWLEDGE_DIR=data/knowledge
# MILVUS_URI=data/milvus.db
# DB_PATH=data/chat.db
# BM25_INDEX_PATH=data/bm25_index.pkl

# ── Embedding 模型（默认在 models/ 下） ────────────────────
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_MODEL_PATH=models/bge-small-zh-v1.5

# ── Query Rewrite ──────────────────────────────────────────
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_SIMILARITY_THRESHOLD=0.7
QUERY_REWRITE_MAX_QUERIES=5

# ── 对话历史窗口 ──────────────────────────────────────────
HISTORY_MAX_TURNS=10

# ── Rerank (Cross-Encoder) ─────────────────────────────────
RERANK_ENABLED=true
# RERANK_MODEL=BAAI/bge-reranker-base
# RERANK_MODEL_PATH=models/bge-reranker-base
RERANK_CANDIDATE_MULTIPLIER=3
RERANK_MAX_LENGTH=512

# ── 缓存 ──────────────────────────────────────────────────
CACHE_SESSION_TTL=3600

# ── Git ───────────────────────────────────────────────────
GIT_ENABLED=true

# ── Redis（可选，不配置则不使用缓存） ─────────────────────
# REDIS_URL=redis://localhost:6379/0
