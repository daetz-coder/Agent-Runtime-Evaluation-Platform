# =============================================================================
# Agent Runtime Evaluation Platform — Docker 环境配置模板
# =============================================================================
# 复制此文件为 .env 并填入你的 API Key：
#   cp .env.docker .env
# =============================================================================

# ── LLM API Keys（至少配一个，否则评估和 Wiki Agent 无法工作） ─────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
ZHIPUAI_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── 生产安全 ────────────────────────────────────────────────────────────
SECRET_KEY=<python -c "import secrets; print(secrets.token_hex(32))">
AUTH_ENABLED=false
API_KEY=

# ── CORS（允许前端的来源域名） ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000","http://localhost"]

# ── 数据库（默认 SQLite，生产建议换 PostgreSQL） ────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/agent_eval.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/agent_eval

# ── Redis（可选，不配则自动降级） ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 评估参数（可选） ───────────────────────────────────────────────────
EVAL_ENABLED=true
EVAL_AUTO_COLLECT=true
EVAL_PARALLEL=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_EVAL_PER_MINUTE=10

# ── 可观测性（可选） ───────────────────────────────────────────────────
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
